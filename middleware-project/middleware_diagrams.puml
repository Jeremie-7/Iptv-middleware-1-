' ══════════════════════════════════════════════════════════════
' DIAGRAMME DE CAS D'UTILISATION
' ══════════════════════════════════════════════════════════════
@startuml cas_utilisation
skinparam backgroundColor #FFFFFF
skinparam actorBackgroundColor #FFFFFF
skinparam actorBorderColor #000000
skinparam usecaseBackgroundColor #FFFFFF
skinparam usecaseBorderColor #000000
skinparam arrowColor #000000
skinparam shadowing false
skinparam linetype ortho
left to right direction

title Cas d'utilisation — Middleware IPTV

actor "STB" as STB
actor "App Python" as PY
actor "Streamer" as STR
actor "Admin" as ADM
actor "Client Web" as CLI

rectangle "Middleware Node.js :3000" {
  usecase "Obtenir sa configuration\n(GET /auth/me)" as UC1
  usecase "Modifier ses abonnements\n(packs / à-la-carte)" as UC2
  usecase "Synchroniser les chaînes\n(POST /chaines/sync)" as UC3
  usecase "Gérer abonnés et packs\n(Dashboard admin)" as UC4
  usecase "S'inscrire / Se connecter\n(pageAbonnee.html)" as UC5
  usecase "Surveiller le système\n(SSE temps réel)" as UC6
}

STB --> UC1
STB --> UC2
PY  --> UC1
PY  --> UC2
STR --> UC3
ADM --> UC4
ADM --> UC6
CLI --> UC5
UC5 ..> UC2 : <<extend>>
UC4 ..> UC6 : <<include>>
@enduml


' ══════════════════════════════════════════════════════════════
' DIAGRAMME DE CLASSES
' ══════════════════════════════════════════════════════════════
@startuml diagramme_classe
skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #000000
skinparam classArrowColor #000000
skinparam shadowing false
skinparam linetype ortho

title Diagramme de Classes — Middleware IPTV

class Client {
  + stb_id : string
  + room : string
  + password_hash : string
  + packs : string[]
  + subscriptions : string[]
}

class Pack {
  + id : string
  + nom : string
  + chaines : string[]
}

class Chaine {
  + id : number
  + name : string
  + multicast.url : string
}

class AuthRoute {
  + GET /auth/me()
  - resolveChannels()
}

class SubscriptionsRoute {
  + POST /packs()
  + POST /channels()
  - resolveIdentity()
  - getRevokedUrls()
}

class AdminRoute {
  + CRUD /clients()
  + CRUD /packs()
  + POST /chaines/sync()
  + GET /stream (SSE)
  + broadcastSSE()
}

class CLIENTS_JSON {
  clients : Client[]
}

class CHAINES_JSON {
  packs : Pack[]
  data : Chaine[]
}

CLIENTS_JSON "1" *-- "0..*" Client
CHAINES_JSON "1" *-- "0..*" Pack
CHAINES_JSON "1" *-- "0..*" Chaine

AuthRoute --> CLIENTS_JSON : lit
AuthRoute --> CHAINES_JSON : lit

SubscriptionsRoute --> CLIENTS_JSON : lit / écrit
SubscriptionsRoute --> CHAINES_JSON : lit
SubscriptionsRoute --> AdminRoute : broadcastSSE()

AdminRoute --> CLIENTS_JSON : lit / écrit
AdminRoute --> CHAINES_JSON : lit / écrit

Client "0..*" -- "0..*" Pack : souscrit
@enduml


' ══════════════════════════════════════════════════════════════
' DIAGRAMME DE SÉQUENCES
' ══════════════════════════════════════════════════════════════
@startuml diagramme_sequences
skinparam backgroundColor #FFFFFF
skinparam sequenceBackgroundColor #FFFFFF
skinparam sequenceArrowColor #000000
skinparam sequenceLifeLineBorderColor #000000
skinparam sequenceParticipantBorderColor #000000
skinparam sequenceParticipantBackgroundColor #FFFFFF
skinparam shadowing false

title Diagramme de Séquences — Middleware IPTV

participant "STB / App Python" as CLI
participant "server.js" as SRV
participant "auth.js" as AUTH
participant "subscriptions.js" as SUBS
participant "admin.js" as ADMIN
participant "CLIENTS.json" as CJSON
participant "CHAINES.json" as CHJSON
participant "Dashboard" as DASH
participant "Streamer" as STR

== Démarrage client (STB ou Python) ==
CLI -> SRV : GET /auth/me + certificat TLS
SRV -> SRV : req.stbId = cert.subject.CN
SRV -> AUTH : route()
AUTH -> CJSON : readClients()
AUTH -> CHJSON : readChaines()
AUTH -> AUTH : resolveChannels()\n= union(packs) + à-la-carte
AUTH -> CLI : {channels:[{name, multicast.url}]}

== Modification abonnement ==
CLI -> SRV : POST /subscriptions/packs\n{action, packId, identifiant, password}
SRV -> SUBS : route()
SUBS -> SUBS : resolveIdentity()\ncert TLS ou mot de passe
SUBS -> CJSON : writeClients()
SUBS -> ADMIN : broadcastSSE(clients)
ADMIN -> DASH : SSE {type:"clients"}
SUBS -> CLI : {success, revokedUrls, channels}

== Révocation (admin retire une chaîne) ==
DASH -> SRV : PUT /admin/clients/stb-01\n{subscriptions:[...]}
SRV -> ADMIN : route()
ADMIN -> ADMIN : getRevokedUrls(avant, après)
ADMIN -> CJSON : writeClients()
ADMIN -> DASH : SSE {type:"access_revoked", urls:[...]}
note right of CLI
  STB / Python détecte
  la révocation au prochain
  refresh → arrête ffplay/cvlc
end note

== Synchronisation Streamer ==
STR -> SRV : POST /admin/chaines/sync\n{data:[chaînes]} + cert
SRV -> ADMIN : route()
ADMIN -> CHJSON : writeChaines()
ADMIN -> DASH : SSE {type:"chaines"}
ADMIN -> STR : {ok:true, count:N}
@enduml


