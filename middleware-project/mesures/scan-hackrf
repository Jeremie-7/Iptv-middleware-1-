import numpy as np
import matplotlib.pyplot as plt
import csv
import time
from hackrf import HackRf

# Fréquences des multiplex (en Hz)
frequencies = [506e6, 546e6, 562e6, 586e6, 642e6]
sample_rate = 2e6  # 2 MHz
duration = 1  # en secondes
n_samples = int(sample_rate * duration)

def scan_frequency(freq):
    # Initialiser la HackRF
    hackrf = HackRf()
    hackrf.setup()
    hackrf.set_sample_rate(sample_rate)
    hackrf.set_freq(freq)

    # Acquisition
    samples = np.zeros(n_samples, dtype=np.complex64)

    def callback(data):
        nonlocal samples
        samples = np.frombuffer(data, dtype=np.complex64)

    hackrf.start_rx(callback)
    import time
    time.sleep(duration)
    hackrf.stop_rx()
    hackrf.close()

    return samples

def save_samples_to_csv(samples, filename):
    with open(filename, 'w', newline='') as csvfile:
        writer = csv.writer(csvfile)
        writer.writerow(['Real', 'Imag'])
        for s in samples:
            writer.writerow([s.real, s.imag])
    print(f"Les données ont été sauvegardées dans {filename}")

def plot_spectrum(samples, freq_center):
    window = np.hanning(len(samples))
    spectrum = np.fft.fftshift(np.fft.fft(samples * window))
    freq_axis = np.fft.fftshift(np.fft.fftfreq(len(samples), d=1/sample_rate))
    plt.plot(freq_axis / 1e6 + freq_center / 1e6, 20*np.log10(np.abs(spectrum)+1e-12))
    plt.xlabel('Fréquence (MHz)')
    plt.ylabel('Amplitude (dB)')
    plt.title(f'Spectre autour de {freq_center/1e6} MHz')
    plt.grid()

plt.figure(figsize=(15, 10))

for i, freq in enumerate(frequencies):
    print(f"Scan de la fréquence {freq/1e6} MHz en cours...")
    samples = scan_frequency(freq)
    filename = f"spectre_{int(freq/1e6)}MHz.csv"
    save_samples_to_csv(samples, filename)
    plt.subplot(3, 2, i+1)
    plot_spectrum(samples, freq)

plt.tight_layout()
plt.show()